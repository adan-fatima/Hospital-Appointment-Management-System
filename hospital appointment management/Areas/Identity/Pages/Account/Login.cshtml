
@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
@* <script src="https://cdn.tailwindcss.com"></script> *@

<div class="min-h-screen bg-slate-50 flex flex-col justify-start pt-8 sm:pt-16 pb-12 sm:px-6 lg:px-8">
    <div class="sm:mx-auto sm:w-full sm:max-w-md">

        <div class="mt-6 sm:mx-auto sm:w-full sm:max-w-md">
            <div class="bg-white py-10 px-6 shadow-lg border border-slate-200 rounded-xl sm:px-10 min-h-[520px] flex flex-col justify-center">

                <!-- Login Heading INSIDE CARD -->
                <div class="text-center mb-8">
                    <h2 class="text-2xl font-bold text-slate-900">
                        Login
                    </h2>
                    <p class="mt-1 text-sm text-slate-500">
                        Access your professional dashboard
                    </p>
                </div>

                <form id="account" method="post" class="space-y-5">
                    <!-- Validation Summary -->
                    <div asp-validation-summary="ModelOnly"
                         class="bg-red-50 border-l-4 border-red-500 p-3 mb-4 text-xs text-red-800"
                         role="alert"></div>

                    <!-- Email -->
                    <div>
                        <label asp-for="Input.Email" class="block text-sm font-semibold text-slate-700 mb-1">
                            Email Address
                        </label>
                        <div class="relative group">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <i class="bi bi-envelope-fill text-slate-400 group-focus-within:text-blue-500 transition-colors"></i>
                            </div>
                            <input asp-for="Input.Email"
                                   class="block w-full pl-10 pr-3 py-2.5 border border-slate-300 rounded-lg bg-slate-50 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white transition-all sm:text-sm"
                                   autocomplete="username" aria-required="true"
                                   placeholder="doctor@hospital.com" />
                        </div>
                        <span asp-validation-for="Input.Email" class="text-xs text-red-500 mt-1 block"></span>
                    </div>

                    <!-- Password -->
                    <div>
                        <label asp-for="Input.Password" class="block text-sm font-semibold text-slate-700 mb-1">
                            Password
                        </label>
                        <div class="relative group">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <i class="bi bi-key-fill text-slate-400 group-focus-within:text-blue-500 transition-colors"></i>
                            </div>
                            <input asp-for="Input.Password"
                                   class="block w-full pl-10 pr-3 py-2.5 border border-slate-300 rounded-lg bg-slate-50 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white transition-all sm:text-sm"
                                   autocomplete="current-password" aria-required="true"
                                   placeholder="••••••••" />
                        </div>
                        <span asp-validation-for="Input.Password" class="text-xs text-red-500 mt-1 block"></span>
                    </div>

                    <!-- Remember Me -->
                    <div class="flex items-center">
                        <input asp-for="Input.RememberMe"
                               class="h-4 w-4 text-blue-600 focus:ring-blue-500 border-slate-300 rounded cursor-pointer" />
                        <label asp-for="Input.RememberMe"
                               class="ml-2 block text-sm text-slate-600 cursor-pointer select-none">
                            @Html.DisplayNameFor(m => m.Input.RememberMe)
                        </label>
                    </div>

                    <!-- Submit -->
                    <div>
                        <button id="login-submit" type="submit"
                                class="w-full flex justify-center py-3 px-4 border border-transparent rounded-lg shadow-sm text-sm font-bold text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition duration-200">
                            Log In
                        </button>
                    </div>
                </form>

                <!-- Register -->
                <div class="mt-8 pt-6 border-t border-slate-100 text-center text-sm">
                    <span class="text-slate-500">Need a professional account?</span>
                    <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl"
                       class="ml-1 font-bold text-blue-600 hover:text-blue-800 transition-colors">
                        Register Now
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        tailwind.config = {
            corePlugins: {
                preflight: false
            }
        }
    </script>
    <script src="https://cdn.tailwindcss.com"></script>
}
