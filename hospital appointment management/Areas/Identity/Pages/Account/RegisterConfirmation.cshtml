@page
@model RegisterConfirmationModel
@{
    ViewData["Title"] = "Registration Status";
}

<h1>@ViewData["Title"]</h1>

<div class="alert alert-info">
    @if (Model.DisplayConfirmAccountLink)
    {
        <p>
            <strong>Step 1:</strong>
            <a id="confirm-link" href="@Model.EmailConfirmationUrl">Click here to confirm your email address.</a>
        </p>
    }
    else
    {
        <p>Please check your email to confirm your account.</p>
    }

    @* Move the Doctor Note OUTSIDE the else block so it always shows for Doctors *@
    <hr />
    <div class="mt-3">
        <h4 class="text-primary">Status: Pending Admin Review</h4>
        <p>
            Your credentials (License & Specialization) are currently being reviewed by our administrative staff.
            Even after confirming your email, you will not be able to log in until an Admin verifies your profile.
        </p>
    </div>
</div>