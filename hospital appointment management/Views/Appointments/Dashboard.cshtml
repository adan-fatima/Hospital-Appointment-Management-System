
@model hospital_appointment_management.Models.PatientDashboardViewModel

<div class="container py-5">

    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h2 class="fw-bold text-dark mb-1">My Health Dashboard</h2>
            <p class="text-muted mb-0">Track your medical journey and appointments</p>
        </div>
        <a asp-controller="Doctors" asp-action="Index" class="btn btn-primary btn-action shadow-sm">
            <i class="bi bi-plus-lg me-2"></i>New Appointment
        </a>
    </div>

    <div class="card dashboard-card shadow-sm mb-5">
        <div class="card-header card-header-gradient bg-white border-bottom d-flex align-items-center">
            <div class="bg-primary bg-opacity-10 p-2 rounded-3 me-3">
                <i class="bi bi-calendar-event text-primary"></i>
            </div>
            <h5 class="mb-0 text-dark fw-bold">Upcoming Appointments</h5>
        </div>

        <div class="card-body p-0">
            @if (!Model.UpcomingAppointments.Any())
            {
                <div class="text-center py-5">
                    <img src="/images/empty-schedule.svg" style="width: 120px; opacity: 0.5;" alt="No appointments" />
                    <p class="text-muted mt-3 mb-0">Your schedule is clear for now.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Doctor</th>
                                <th>Schedule</th>
                                <th>Status</th>
                                <th class="text-end px-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.UpcomingAppointments)
                            {
                                @if (item.Status != AppointmentStatus.Completed)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <div class="avatar-sm bg-light rounded-circle me-3 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                                    <i class="bi bi-person text-secondary"></i>
                                                </div>
                                                <span class="fw-bold text-dark">Dr. @item.Doctor.FirstName @item.Doctor.LastName</span>
                                            </div>
                                        </td>
                                        <td>
                                            <div class="text-dark fw-medium">@item.AppointmentDate.ToString("MMM dd, yyyy")</div>
                                            <div class="text-muted small"><i class="bi bi-clock me-1"></i> @item.AppointmentTime</div>
                                        </td>
                                        <td>
                                            <span class="badge badge-subtle @(item.Status == AppointmentStatus.Approved ? "bg-success-subtle" : "bg-warning-subtle")">
                                                <i class="bi bi-circle-fill me-1" style="font-size: 0.5rem;"></i> @item.Status
                                            </span>
                                        </td>
                                        <td class="text-end px-4">
                                            @if (item.Status != AppointmentStatus.Cancelled)
                                            {
                                                <form asp-action="Cancel" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Cancel this appointment?');" class="d-inline">
                                                    <button type="submit" class="btn btn-action btn-outline-danger btn-sm">
                                                        Cancel
                                                    </button>
                                                </form>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <div class="card dashboard-card shadow-sm">
        <div class="card-header card-header-gradient bg-white border-bottom d-flex align-items-center">
            <div class="bg-secondary bg-opacity-10 p-2 rounded-3 me-3">
                <i class="bi bi-clock-history text-secondary"></i>
            </div>
            <h5 class="mb-0 text-dark fw-bold">Appointment History</h5>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-sm table-hover mb-0">
                    <thead>
                        <tr>
                            <th class="ps-4">Doctor</th>
                            <th>Date</th>
                            <th>Status</th>
                            <th class="text-end pe-4">Feedback</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.PastAppointments)
                        {
                            <tr>
                                <td class="ps-4 py-3">
                                    <span class="text-dark">Dr. @item.Appointment.Doctor.FirstName @item.Appointment.Doctor.LastName</span>
                                </td>
                                <td>@item.Appointment.AppointmentDate.ToString("dd MMM yyyy")</td>
                                <td>
                                    <span class="badge badge-subtle @(item.Appointment.Status == AppointmentStatus.Completed ? "bg-info-subtle" : "bg-danger-subtle")">
                                        @item.Appointment.Status
                                    </span>
                                </td>
                                <td class="text-end pe-4">
                                    @if (item.Appointment.Status == AppointmentStatus.Completed && !item.HasFeedback)
                                    {
                                        <a asp-controller="Feedbacks" asp-action="Create" asp-route-appointmentId="@item.Appointment.Id" class="btn btn-sm btn-primary btn-action">
                                            Give Feedback
                                        </a>
                                    }
                                    else if (item.HasFeedback)
                                    {
                                        <span class="text-success small fw-bold"><i class="bi bi-check2-circle me-1"></i>Reviewed</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">-</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
<style>
    :root {
        --card-border-radius: 16px;
        --medical-blue: #2563eb;
        --medical-gray: #64748b;
    }

    /* Card Styling */
    .dashboard-card {
        border-radius: var(--card-border-radius) !important;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        border: 1px solid rgba(0,0,0,0.05) !important;
    }

    .card-header-gradient {
        border-radius: var(--card-border-radius) var(--card-border-radius) 0 0 !important;
        padding: 1.25rem 1.5rem !important;
        font-weight: 600;
    }

    /* Table Enhancements */
    .table thead th {
        background-color: #f8fafc;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.05em;
        color: var(--medical-gray);
        border-top: none;
        padding: 1rem;
    }

    .table tbody td {
        padding: 1rem;
        vertical-align: middle;
    }

    /* Modern Status Badges */
    .badge-subtle {
        font-weight: 500;
        padding: 0.5em 1em;
        border-radius: 6px;
    }

    .bg-success-subtle {
        background-color: #dcfce7 !important;
        color: #166534 !important;
    }

    .bg-warning-subtle {
        background-color: #fef9c3 !important;
        color: #854d0e !important;
    }

    .bg-danger-subtle {
        background-color: #fee2e2 !important;
        color: #991b1b !important;
    }

    .bg-info-subtle {
        background-color: #e0f2fe !important;
        color: #075985 !important;
    }

    /* Interactive Elements */
    .btn-action {
        border-radius: 8px;
        padding: 0.4rem 1rem;
        transition: all 0.2s ease;
    }

        .btn-action:hover {
            transform: translateY(-1px);
        }
</style>