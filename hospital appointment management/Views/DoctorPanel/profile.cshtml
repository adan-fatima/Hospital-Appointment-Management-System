
@model hospital_appointment_management.Models.DoctorProfile

<div class="container py-5">
    <div class="card dr-profile-card shadow-lg border-0">

        <div class="card-header bg-white border-0 pt-5 px-4 px-md-5">
            <div class="row align-items-center">
                <div class="col-md-auto text-center text-md-start mb-3 mb-md-0">
                    <div class="dr-img-wrapper shadow-sm">
                        <img src="@(string.IsNullOrEmpty(Model.ProfileImagePath) ? "/images/default-doctor.jpg" : Model.ProfileImagePath)"
                             class="dr-profile-img"
                             alt="Doctor Image" />
                    </div>
                </div>
                <div class="col-md text-center text-md-start ms-md-4">
                    <h1 class="display-5 fw-bold text-dark mb-1">Dr. @Model.FullName</h1>
                    <p class="h4 text-primary fw-medium mb-3">@Model.Specialization</p>

                    <div class="d-flex flex-wrap justify-content-center justify-content-md-start gap-2">
                        <span class="badge-soft @(Model.IsProfileComplete ? "badge-soft-success" : "badge-soft-warning")">
                            <i class="bi @(Model.IsProfileComplete ? "bi-check-circle-fill" : "bi-exclamation-triangle-fill")"></i>
                            @(Model.IsProfileComplete ? "Profile Complete" : "Profile Incomplete")
                        </span>
                        <span class="badge-soft border bg-light text-dark">
                            <i class="bi bi-award-fill text-warning"></i> @Model.ExperienceYears+ Years Experience
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <div class="card-body px-4 px-md-5 py-4">
            <div class="row">
                <div class="col-lg-4 mb-4">
                    <div class="bg-light rounded-4 p-4 h-100">
                        <h5 class="fw-bold mb-4 text-dark"><i class="bi bi-info-circle me-2"></i>Contact Details</h5>

                        <div class="mb-3">
                            <small class="text-muted d-block text-uppercase fw-bold" style="font-size: 0.7rem;">Email Address</small>
                            <span class="text-dark fw-medium">@Model.Doctor.Email</span>
                        </div>

                        <div class="mb-3">
                            <small class="text-muted d-block text-uppercase fw-bold" style="font-size: 0.7rem;">Account Status</small>
                            <span class="text-info fw-bold">Active Member</span>
                        </div>

                        <div class="mt-4 pt-3 border-top">
                            <p class="small text-muted mb-0 italic">Member since: @DateTime.Now.Year</p>
                        </div>
                    </div>
                </div>

                <div class="col-lg-8">
                    <div class="ps-lg-4">
                        <h5 class="fw-bold mb-3 text-dark border-bottom pb-2">Professional Biography</h5>
                        <p class="bio-text">
                            @(string.IsNullOrEmpty(Model.Bio) ? "No biography provided yet. Please edit your profile to add your professional background." : Model.Bio)
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <div class="card-footer bg-white border-0 p-4 px-md-5 d-flex flex-column flex-sm-row justify-content-between align-items-center gap-3">
            <a asp-action="Index" class="btn btn-modern btn-outline-secondary w-100 w-sm-auto">
                <i class="bi bi-arrow-left me-2"></i>Back to Dashboard
            </a>
            <a asp-action="EditProfile" class="btn btn-modern btn-primary-modern text-white w-100 w-sm-auto">
                <i class="bi bi-pencil-square me-2"></i>Edit My Profile
            </a>
        </div>
    </div>
</div>