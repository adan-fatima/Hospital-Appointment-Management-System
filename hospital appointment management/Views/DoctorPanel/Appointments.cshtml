
@model PatientDashboardViewModel

<div class="container py-5">
    <div class="d-flex align-items-center justify-content-between mb-5">
        <div>
            <h2 class="fw-bold text-dark mb-1">Doctor Schedule</h2>
            <p class="text-muted small mb-0">Manage your daily and upcoming patient workflow</p>
        </div>
        <div class="bg-primary bg-opacity-10 p-3 rounded-circle d-none d-md-block">
            <i class="fa-solid fa-user-doctor text-primary fs-3"></i>
        </div>
    </div>

    <div class="mb-5">
        <div class="d-flex align-items-center mb-3">
            <div class="bg-primary rounded-pill me-2" style="width: 4px; height: 24px;"></div>
            <h5 class="fw-bold text-dark mb-0">
                <i class="fa-solid fa-calendar-day me-2 text-primary"></i> Today's Appointments
            </h5>
        </div>

        <div class="table-container table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Patient</th>
                        <th>Time</th>
                        <th>Status</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.TodayAppointments.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5 text-muted fst-italic">No appointments scheduled for today.</td>
                        </tr>
                    }
                    @foreach (var app in Model.TodayAppointments)
                    {
                        <tr>
                            <td>
                                <div class="fw-bold text-dark">@app.Patient.FirstName @app.Patient.LastName</div>
                             
                            </td>
                            <td>
                                <span class="fw-medium text-dark"><i class="fa-regular fa-clock me-1 text-muted"></i> @app.AppointmentTime</span>
                            </td>
                            <td>
                                <span class="badge badge-soft badge-soft-success">
                                    <i class="fa-solid fa-circle me-1" style="font-size: 0.5rem;"></i> @app.Status
                                </span>
                            </td>
                            <td class="text-end">
                                @if (app.Status == AppointmentStatus.Approved)
                                {
                                    <form asp-action="UpdateStatus" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@app.Id" />
                                        <input type="hidden" name="newStatus" value="@AppointmentStatus.Completed" />
                                        <button class="btn btn-sm btn-primary btn-action px-3">
                                            Mark Completed
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div>
        <div class="d-flex align-items-center mb-3">
            <div class="bg-secondary rounded-pill me-2" style="width: 4px; height: 24px;"></div>
            <h5 class="fw-bold text-dark mb-0">
                <i class="fa-solid fa-calendar-plus me-2 text-secondary"></i> Upcoming Appointments
            </h5>
        </div>

        <div class="table-container table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Patient</th>
                        <th>Date</th>
                        <th>Time</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.UpcomingAppointments.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted fst-italic">No upcoming appointments found.</td>
                        </tr>
                    }
                    @foreach (var app in Model.UpcomingAppointments)
                    {
                        <tr>
                            <td class="fw-bold text-dark">@app.Patient.FirstName @app.Patient.LastName</td>
                            <td><i class="fa-regular fa-calendar me-1 text-muted"></i> @app.AppointmentDate.ToShortDateString()</td>
                            <td>@app.AppointmentTime</td>
                            <td>
                                <span class="badge badge-soft badge-soft-info">@app.Status</span>
                            </td>
                            <td class="text-end">
                                <form asp-action="UpdateStatus" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@app.Id" />
                                    <input type="hidden" name="newStatus" value="@AppointmentStatus.Cancelled" />
                                    <button class="btn btn-sm btn-outline-danger btn-action px-3" onclick="return confirm('Cancel this appointment?')">
                                        <i class="fa-solid fa-xmark me-1"></i> Cancel
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
