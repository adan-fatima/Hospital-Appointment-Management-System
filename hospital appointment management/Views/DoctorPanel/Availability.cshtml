@model IEnumerable<hospital_appointment_management.Models.DoctorBlockout>

<div class="container py-5">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">Manage My Availability</h2>
            <p class="text-muted">Set your off-days or specific time blocks to prevent new bookings.</p>
        </div>
        <i class="bi bi-calendar2-range fs-1 text-primary opacity-25"></i>
    </div>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success alert-modern mb-4 animate__animated animate__fadeIn">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Message"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-modern mb-4 animate__animated animate__shakeX">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
        </div>
    }

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card custom-card">
                <div class="card-header bg-dark text-white py-3">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-plus-circle me-2"></i>Add Blockout</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="BlockTime" method="post">
                        <div class="mb-4">
                            <label class="form-label fw-semibold">Select Date</label>
                            <input type="date" name="date" class="form-control form-control-modern"
                                   required min="@DateTime.Now.ToString("yyyy-MM-dd")" />
                        </div>

                        <div class="form-check form-switch mb-4">
                            <input type="checkbox" name="fullDay" class="form-check-input" value="true" id="fullDayCheck">
                            <label class="form-check-label fw-bold" for="fullDayCheck">Full Day Off</label>
                        </div>

                        <div id="timeInputs" class="bg-light p-3 rounded-3 mb-4">
                            <div class="mb-3">
                                <label class="form-label small text-muted text-uppercase">Start Time</label>
                                <input type="time" name="start" class="form-control form-control-modern" />
                            </div>
                            <div class="mb-0">
                                <label class="form-label small text-muted text-uppercase">End Time</label>
                                <input type="time" name="end" class="form-control form-control-modern" />
                            </div>
                        </div>

                        <button type="submit" class="btn btn-danger w-100 py-3 fw-bold rounded-pill shadow-sm transition-all">
                            Block Selected Time
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card custom-card">
                <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold text-dark">Current Blocked Dates</h5>
                    <span class="badge bg-light text-dark border">@Model.Count() Active Blocks</span>
                </div>
                <div class="table-responsive">
                    <table class="table table-modern table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th class="ps-4">Date</th>
                                <th>Schedule Type</th>
                                <th class="text-end pe-4">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center">
                                            <div class="bg-primary bg-opacity-10 p-2 rounded-3 me-3">
                                                <i class="bi bi-calendar-event text-primary"></i>
                                            </div>
                                            <span class="fw-bold">@item.BlockoutDate.ToString("ddd, MMM dd yyyy")</span>
                                        </div>
                                    </td>
                                    <td>
                                        @if (item.IsFullDay)
                                        {
                                            <span class="badge rounded-pill bg-danger bg-opacity-10 text-danger px-3 py-2">
                                                <i class="bi bi-moon-stars-fill me-1"></i> Full Day
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge rounded-pill bg-info bg-opacity-10 text-info px-3 py-2">
                                                <i class="bi bi-clock me-1"></i> @item.StartTime to @item.EndTime
                                            </span>
                                        }
                                    </td>
                                    <td class="text-end pe-4">
                                        <form asp-action="DeleteBlockout" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3"
                                                    onclick="return confirm('Restore availability for this date?')">
                                                <i class="bi bi-trash-fill"></i> Remove
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>